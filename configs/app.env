# monitor-system unified runtime configuration.
# Keep module-local config files for standalone development, and use this file
# as the default entry point for compose and host-side manager runs.

# MySQL, used by docker compose and host-side manager.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=monitor-system

# Redis, used by host-side manager.
MANAGER_REDIS_ENABLED=true
MANAGER_REDIS_URI=tcp://127.0.0.1:6379

# Manager tuning. Manager is intentionally not started by docker compose.
MANAGER_GRPC_ADDR=127.0.0.1:50051
MANAGER_GRPC_NUM_CQS=4
MANAGER_GRPC_MIN_POLLERS=4
MANAGER_GRPC_MAX_POLLERS=8
MANAGER_TASK_QUEUE_CAPACITY=10000
MANAGER_TASK_QUEUE_HIGH_WATERMARK=8000
MANAGER_TASK_QUEUE_LOW_WATERMARK=3000
MANAGER_TASK_TIMEOUT_MS=3000
MANAGER_INGEST_SHARD_COUNT=8
MANAGER_INGEST_QUEUE_CAPACITY_PER_SHARD=2048
MANAGER_QUERY_QUEUE_CAPACITY=10000
MANAGER_QUERY_QUEUE_HIGH_WATERMARK=8000
MANAGER_QUERY_QUEUE_LOW_WATERMARK=3000
MANAGER_QUERY_THREADS_MIN=4
MANAGER_QUERY_THREADS_MAX=16
MANAGER_QUERY_IDLE_SHRINK_SECONDS=30
MANAGER_BUSINESS_THREADS_MIN=4
MANAGER_BUSINESS_THREADS_MAX=16
MANAGER_BUSINESS_IDLE_SHRINK_SECONDS=30
MANAGER_MYSQL_WRITE_POOL_MIN=2
MANAGER_MYSQL_WRITE_POOL_MAX=8
MANAGER_MYSQL_QUERY_POOL_MIN=2
MANAGER_MYSQL_QUERY_POOL_MAX=8
MANAGER_MYSQL_CONNECT_TIMEOUT_MS=1000
MANAGER_MYSQL_READ_TIMEOUT_MS=2000
MANAGER_MYSQL_HEALTH_CHECK_SECONDS=10
MANAGER_MYSQL_IDLE_TTL_SECONDS=60
MANAGER_REDIS_POOL_MIN=2
MANAGER_REDIS_POOL_MAX=8
MANAGER_REDIS_CONNECT_TIMEOUT_MS=500
MANAGER_REDIS_READ_TIMEOUT_MS=1000
MANAGER_REDIS_HEALTH_CHECK_SECONDS=10
MANAGER_REDIS_IDLE_TTL_SECONDS=60
MANAGER_REDIS_CACHE_TTL_SECONDS=5
MANAGER_VERBOSE_LOG=false
MANAGER_METRICS_LOG_INTERVAL_SECONDS=10

# api_gateway. Docker uses DOCKER_MANAGER_GRPC_ADDR so the container can reach
# the host-side manager.
API_GATEWAY_PORT=8080
API_GATEWAY_VERSION=v0.1.0
GIN_MODE=debug
MANAGER_GRPC_TIMEOUT=5s
DOCKER_MANAGER_GRPC_ADDR=host.docker.internal:50051

# agent_service. Docker-specific addresses point to compose services.
AGENT_SERVICE_PORT=6872
API_GATEWAY_BASE_URL=http://127.0.0.1:8080
DOCKER_API_GATEWAY_BASE_URL=http://api_gateway:8080
MILVUS_ADDR=127.0.0.1:19530
DOCKER_MILVUS_ADDR=milvus:19530
AGENT_DOCS_DIR=./docs
AGENT_THINK_API_KEY=
AGENT_THINK_BASE_URL=
AGENT_THINK_MODEL=
AGENT_QUICK_API_KEY=
AGENT_QUICK_BASE_URL=
AGENT_QUICK_MODEL=
AGENT_EMBEDDING_API_KEY=
AGENT_EMBEDDING_MODEL=text-embedding-v4

# web.
WEB_PORT=3000
