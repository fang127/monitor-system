# MySQL database connection settings
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=monitor-system

# gRPC sync server concurrency
MANAGER_GRPC_NUM_CQS=4 # grpc队列数量
MANAGER_GRPC_MIN_POLLERS=4 # grpc最小线程数
MANAGER_GRPC_MAX_POLLERS=8 # grpc最大线程数

# Unified business task queue
MANAGER_TASK_QUEUE_CAPACITY=10000 # 任务队列容量
MANAGER_TASK_QUEUE_HIGH_WATERMARK=8000 # 任务队列高水位线，达到后会触发限流
MANAGER_TASK_QUEUE_LOW_WATERMARK=3000 # 任务队列低水位线，达到后会解除限流
MANAGER_TASK_TIMEOUT_MS=3000 # 任务超时时间，单位毫秒

# Ordered worker ingest shards
MANAGER_INGEST_SHARD_COUNT=8 # ingest分片数量，决定了并发处理能力和数据分布
MANAGER_INGEST_QUEUE_CAPACITY_PER_SHARD=2048 # 每个ingest分片的队列容量，达到后会触发限流

# Concurrent query queue and worker pool
MANAGER_QUERY_QUEUE_CAPACITY=10000 # 查询队列容量
MANAGER_QUERY_QUEUE_HIGH_WATERMARK=8000 # 查询队列高水位线，达到后会触发限流
MANAGER_QUERY_QUEUE_LOW_WATERMARK=3000 # 查询队列低水位线，达到后会解除限流
MANAGER_QUERY_THREADS_MIN=4 # 查询线程池最小线程数
MANAGER_QUERY_THREADS_MAX=16 # 查询线程池最大线程数
MANAGER_QUERY_IDLE_SHRINK_SECONDS=30 # 查询线程池空闲收缩时间，单位秒

# MySQL write connection pool
MANAGER_MYSQL_WRITE_POOL_MIN=2 # MySQL写连接池最小连接数
MANAGER_MYSQL_WRITE_POOL_MAX=8 # MySQL写连接池最大连接数

# MySQL query connection pool
MANAGER_MYSQL_QUERY_POOL_MIN=2 # MySQL查询连接池最小连接数
MANAGER_MYSQL_QUERY_POOL_MAX=8 # MySQL查询连接池最大连接数

# MySQL connection health and timeout controls
MANAGER_MYSQL_CONNECT_TIMEOUT_MS=1000 # MySQL连接超时时间，单位毫秒
MANAGER_MYSQL_READ_TIMEOUT_MS=2000 # MySQL读取超时时间，单位毫秒
MANAGER_MYSQL_HEALTH_CHECK_SECONDS=10 # MySQL连接健康检查间隔时间，单位秒
MANAGER_MYSQL_IDLE_TTL_SECONDS=60 # MySQL连接空闲TTL时间，单位秒，超过后会被回收

# Redis cache connection pool
MANAGER_REDIS_ENABLED=true # 是否启用Redis缓存
MANAGER_REDIS_URI=tcp://127.0.0.1:6379 # Redis连接URI，格式为tcp://host:port
MANAGER_REDIS_POOL_MIN=2 # Redis连接池最小连接数
MANAGER_REDIS_POOL_MAX=8 # Redis连接池最大连接数
MANAGER_REDIS_CONNECT_TIMEOUT_MS=500 # Redis连接超时时间，单位毫秒
MANAGER_REDIS_READ_TIMEOUT_MS=1000 # Redis读取超时时间，单位毫秒
MANAGER_REDIS_HEALTH_CHECK_SECONDS=10 # Redis连接健康检查间隔时间，单位秒
MANAGER_REDIS_IDLE_TTL_SECONDS=60 # Redis连接空闲TTL时间，单位秒，超过后会被回收
MANAGER_REDIS_CACHE_TTL_SECONDS=5 # Redis缓存TTL时间，单位秒，超过后会被自动删除

# Logging and metrics
MANAGER_VERBOSE_LOG=false # 是否启用详细日志，启用后会输出更多调试信息，可能会影响性能
MANAGER_METRICS_LOG_INTERVAL_SECONDS=10 # 监控日志输出间隔时间，单位秒，启用后会定期输出系统性能指标日志
