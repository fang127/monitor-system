# MySQL database connection settings
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=monitor-system

# gRPC sync server concurrency
MANAGER_GRPC_NUM_CQS=4
MANAGER_GRPC_MIN_POLLERS=8
MANAGER_GRPC_MAX_POLLERS=64

# Unified business task queue
MANAGER_TASK_QUEUE_CAPACITY=10000
MANAGER_TASK_QUEUE_HIGH_WATERMARK=8000
MANAGER_TASK_QUEUE_LOW_WATERMARK=3000
MANAGER_TASK_TIMEOUT_MS=3000

# Ordered worker ingest shards
MANAGER_INGEST_SHARD_COUNT=8
MANAGER_INGEST_QUEUE_CAPACITY_PER_SHARD=2048

# Concurrent query queue and worker pool
MANAGER_QUERY_QUEUE_CAPACITY=10000
MANAGER_QUERY_QUEUE_HIGH_WATERMARK=8000
MANAGER_QUERY_QUEUE_LOW_WATERMARK=3000
MANAGER_QUERY_THREADS_MIN=4
MANAGER_QUERY_THREADS_MAX=16
MANAGER_QUERY_IDLE_SHRINK_SECONDS=30

# MySQL write connection pool
MANAGER_MYSQL_WRITE_POOL_MIN=2
MANAGER_MYSQL_WRITE_POOL_MAX=4

# MySQL query connection pool
MANAGER_MYSQL_QUERY_POOL_MIN=4
MANAGER_MYSQL_QUERY_POOL_MAX=8

# MySQL connection health and timeout controls
MANAGER_MYSQL_CONNECT_TIMEOUT_MS=1000
MANAGER_MYSQL_READ_TIMEOUT_MS=2000
MANAGER_MYSQL_HEALTH_CHECK_SECONDS=10
MANAGER_MYSQL_IDLE_TTL_SECONDS=60

# Redis cache connection pool
MANAGER_REDIS_ENABLED=true
MANAGER_REDIS_URI=tcp://127.0.0.1:6379
MANAGER_REDIS_POOL_MIN=2
MANAGER_REDIS_POOL_MAX=8
MANAGER_REDIS_CONNECT_TIMEOUT_MS=500
MANAGER_REDIS_READ_TIMEOUT_MS=1000
MANAGER_REDIS_HEALTH_CHECK_SECONDS=10
MANAGER_REDIS_IDLE_TTL_SECONDS=60
MANAGER_REDIS_CACHE_TTL_SECONDS=5

# Logging and metrics
MANAGER_VERBOSE_LOG=false
MANAGER_METRICS_LOG_INTERVAL_SECONDS=10
